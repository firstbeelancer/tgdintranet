# ==========================================
# tgdintranet — Environment Variables
# Copy to .env and fill required values
# ==========================================

# ─── Required ────────────────────────────

# PostgreSQL password (должен быть сильным)
DB_PASS=change_me_to_32_char_random_string

# JWT secret (минимум 32 символа)
JWT_SECRET=change-me-in-production-min-32-chars-long

# AES-256-GCM encryption key (32 bytes = 64 hex chars) — для будущего шифрования
ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b

# Домен приложения (для CORS)
DOMAIN=intranet.tigerapps.pro

# ─── Database / Redis (auto-set in Docker Compose) ───

DB_USER=tgdintranet
DB_NAME=tgdintranet
DATABASE_URL=postgresql://tgdintranet:${DB_PASS}@db:5432/tgdintranet

# ─── Seed admin (используется при первом старте, если БД пустая) ───

SEED_ADMIN_EMAIL=admin@intranet.local
SEED_ADMIN_PASSWORD=Admin2026!Demo
SEED_MARKETER_EMAIL=marketer@intranet.local
SEED_MARKETER_PASSWORD=Marketer2026!Demo
SEED_USER_EMAIL=user@intranet.local
SEED_USER_PASSWORD=User2026!Demo
